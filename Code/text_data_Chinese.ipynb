    "text = \"南京市长江大桥欢迎您\"\n",
    "print(jieba.lcut(text))     # 精确模式\n",
    "print(jieba.lcut(text, cut_all = True))  # 所有可能的组合\n",
    "print(list(jieba.cut_for_search(text)))  # 标准答案 + 精确分词 + 子词补充"
